PORT=8000
CORS_ORIGIN=http://localhost:5173
MODEL_ENDPOINT=http://localhost:5000/colorize

# ZaloPay sandbox
ZALOPAY_APP_ID=your_zalopay_app_id
ZALOPAY_KEY1=your_zalopay_key1
ZALOPAY_KEY2=your_zalopay_key2
ZALOPAY_CREATE_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
ZALOPAY_CALLBACK_URL=https://your-domain.com/api/payments/webhook
ZALOPAY_VND_PER_USD=25000

# VietQR quick link
# VIETQR_BANK_ID can be bank short name such as mbbank, vietcombank, acb, techcombank
# or a bank BIN supported by VietQR.
VIETQR_BANK_ID=mbbank
VIETQR_ACCOUNT_NO=0961856252
VIETQR_ACCOUNT_NAME=NGUYEN LAM ANH TUAN
VIETQR_TEMPLATE=print
VIETQR_VND_PER_USD=25000

# Transfer content. Leave fixed content empty to use a stable 4-digit user code.
# Example generated content: 1197
VIETQR_TRANSFER_PREFIX=
VIETQR_TRANSFER_CONTENT=
# PayPal manual payment
PAYPAL_PAYMENT_URL=https://paypal.me/relookai
PAYPAL_TRANSFER_CONTENT=
PAYPAL_INCLUDE_CURRENCY=false
